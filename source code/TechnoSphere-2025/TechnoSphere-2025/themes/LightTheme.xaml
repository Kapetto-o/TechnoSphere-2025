<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/font/FontStyle.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    
    <Color x:Key="WhiteColor">#FFFFFF</Color>
    <Color x:Key="GreenColor">#1A5832</Color>
    <Color x:Key="Light_greenColor">#387A2B</Color>
    <Color x:Key="GrayColor">#353535</Color>

    <SolidColorBrush x:Key="BrushWhiteColor" Color="{DynamicResource WhiteColor}"/>
    <SolidColorBrush x:Key="BrushGreenColor" Color="{DynamicResource GreenColor}"/>
    <SolidColorBrush x:Key="BrushLight_greenColorColor" Color="{DynamicResource Light_greenColor}"/>
    <SolidColorBrush x:Key="BrushGrayColor" Color="{DynamicResource GrayColor}"/>

    <!-- Фон -->
    <Style x:Key="BackgroundColor" TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource BrushWhiteColor}"/>
    </Style>

     <!-- Второстепенный фон --> 
    <Style x:Key="ForegraundColor" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource BrushGreenColor}"/>
    </Style>
    
    <!-- Заголовки_1 -->
    <Style x:Key="Headline_1" TargetType="TextBlock" BasedOn="{StaticResource Headline_1}">
        <Setter Property="Foreground" Value="{DynamicResource WhiteColor}"/>
    </Style>
    
    <!-- Заголовки_2 -->
    <Style x:Key="Headline_2" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource GreenColor}"/>
    </Style>
    
    <!-- Основной текст -->
    <Style x:Key="Textline" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource BrushGrayColor}"/>
    </Style>
</ResourceDictionary>