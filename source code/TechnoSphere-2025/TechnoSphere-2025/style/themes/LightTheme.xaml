<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/style/font/FontStyle.xaml"/>
        <ResourceDictionary Source="/style/Style.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    
    <Color x:Key="WhiteColor">#FFFFFF</Color>
    <Color x:Key="GreenColor">#1A5832</Color>
    <Color x:Key="Light_greenColor">#387A2B</Color>
    <Color x:Key="GrayColor">#353535</Color>

    <SolidColorBrush x:Key="BrushWhiteColor" Color="{DynamicResource WhiteColor}"/>
    <SolidColorBrush x:Key="BrushGreenColor" Color="{DynamicResource GreenColor}"/>
    <SolidColorBrush x:Key="BrushLight_greenColor" Color="{DynamicResource Light_greenColor}"/>
    <SolidColorBrush x:Key="BrushGrayColor_2" Color="{DynamicResource GrayColor}"/>

    <!-- Фон -->
    <Style x:Key="BackgroundColor" TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource BrushWhiteColor}"/>
    </Style>

    <!-- Второстепенный фон --> 
    <Style x:Key="ForegraundColor" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource BrushGreenColor}"/>
    </Style>
    
    <!-- Управление окном -->
    <!-- Скрыть окно -->
    <Style x:Key="HideColor_1" TargetType="Button" BasedOn="{StaticResource ShowButtonStyle}">
        <Setter Property="Foreground"  Value="{DynamicResource BrushGreenColor}"/>
    </Style>
    <Style x:Key="HideColor_2" TargetType="Button" BasedOn="{StaticResource ShowButtonStyle}">
        <Setter Property="Foreground"  Value="{DynamicResource BrushWhiteColor}"/>
    </Style>
   
    <!-- Удалить окно -->
    <Style x:Key="CloseColor_1" TargetType="Button" BasedOn="{StaticResource CloseButtonStyle}">
        <Setter Property="Foreground"  Value="{DynamicResource BrushGreenColor}"/>
    </Style>
    <Style x:Key="CloseColor_2" TargetType="Button" BasedOn="{StaticResource CloseButtonStyle}">
        <Setter Property="Foreground"  Value="{DynamicResource BrushWhiteColor}"/>
    </Style>

    <!-- Текст -->
    <!-- Заголовок_1 цвет_1 -->
    <Style x:Key="HeadlineColor_1_1" TargetType="TextBlock" BasedOn="{StaticResource Headline_1}">
        <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor}"/>
    </Style>

    <!-- Заголовок_1 цвет_2 -->
    <Style x:Key="HeadlineColor_1_2" TargetType="TextBlock"  BasedOn="{StaticResource Headline_1}">
        <Setter Property="Foreground" Value="{DynamicResource BrushGreenColor}"/>
    </Style>

    <!-- Заголовок_2 -->
    <Style x:Key="HeadlineColor_2" TargetType="TextBlock"  BasedOn="{StaticResource Headline_2}">
        <Setter Property="Foreground" Value="{DynamicResource BrushGreenColor}"/>
    </Style>
    
    <!-- Основной_1 -->
    <Style x:Key="MainlineColor_1" TargetType="TextBlock" BasedOn="{StaticResource Mainline_1}">
        <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor}"/>
    </Style>

    <!-- Основной_2 -->
    <Style x:Key="MainlineColor_2" TargetType="TextBlock" BasedOn="{StaticResource Mainline_2}">
        <Setter Property="Foreground" Value="{DynamicResource BrushGrayColor_2}"/>
    </Style>

    <!-- Элементы управления -->
    <!-- TextBox в окнах регистрации и авторизации -->
    <Style x:Key="TextBoxColor" TargetType="TextBox" BasedOn="{StaticResource RegAut_TextBox}">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushGrayColor_2}"/>
        <Setter Property="Background" Value="{DynamicResource BrushWhiteColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushGrayColor_2}"/>
    </Style>

    <!-- Button в окнах регистрации и авторизации -->
    <Style x:Key="ButtonColor" TargetType="Button" BasedOn="{StaticResource RegAut_Button}">
        <Setter Property="Background" Value="{DynamicResource BrushGreenColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor}"/>
    </Style>

    <!-- Иконки -->
    <Style x:Key="IconColor" TargetType="Button" BasedOn="{StaticResource IconStyle}">
        <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BrushLight_greenColor}"/>
                <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- Логотип -->
    <Style x:Key="LogoColor" TargetType="Button" BasedOn="{StaticResource IconStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Image x:Name="ImageElement" Source="{DynamicResource LogoFullWhite}" Height="25"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ПРОВЕРЕНО ВЫШЕ -->
    <!-- ПРОВЕРЕНО ВЫШЕ -->
    <!-- ПРОВЕРЕНО ВЫШЕ -->

    <!-- Поиск -->
    <!-- Поле ввода поиска -->
    <Style x:Key="SearchTextboxColor" TargetType="TextBox" BasedOn="{StaticResource RegAut_TextBox}">
        <Setter Property="Background" Value="{DynamicResource BrushWhiteColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrushGrayColor_2}"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushGrayColor_2}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Height" Value="35"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Кнопка поиска -->
    <Style x:Key="SearchButtonColor" TargetType="Button" BasedOn="{StaticResource SearchIconStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Image x:Name="ImageElement" Source="{DynamicResource SearchWhite}" Height="35"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Иконка сравнения -->
    <Style x:Key="CompramiseButtonColor" TargetType="Button" BasedOn="{StaticResource IconStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Image x:Name="ImageElement" Source="{DynamicResource ComprarisonWhite}" Height="35"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- Иконка избранного -->
    <!-- Иконка корзины -->
</ResourceDictionary>