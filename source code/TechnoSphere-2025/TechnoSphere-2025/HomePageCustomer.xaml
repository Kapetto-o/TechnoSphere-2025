<Page x:Class="TechnoSphere_2025.HomePageCustomer"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TechnoSphere_2025"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="HomePageCustomer">
    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Style="{DynamicResource ForegraundColor}">
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="45"/>
            </Grid.RowDefinitions>
            
            <!-- Header_1 -->
            <Grid Grid.Row="0" Margin="15,0,70,0">
                <Button x:Name="LogoSetting"
                        Style="{DynamicResource LogoColor}"
                        HorizontalAlignment="Left">
                </Button>
                <Button x:Name="UserAccount"
                        Style="{DynamicResource IconColor}"
                        HorizontalAlignment="Right"
                        ClipToBounds="True"
                        Width="130">
                    <TextBlock Text="Kapetto"
                               Style="{StaticResource Headerline}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>
            </Grid>
            
            <!-- Header_2 -->
            <Grid Grid.Row="1" Margin="7,0,15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="43"/>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <Grid x:Name="BurgerMenu" Grid.Column="0"  ClipToBounds="True">
                    <Button Style="{DynamicResource IconColor}"
                            ContentTemplate="{StaticResource BurgerIconTemplate}"
                            ClipToBounds="True"/>
                </Grid>
                <Grid Grid.Column="1" Margin="5,0,0,0">
                    <Button Style="{DynamicResource IconColor}">
                        <TextBlock Text="Акции"
                                   Style="{StaticResource Headerline}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Button>
                </Grid>
                <Grid Grid.Column="2" Margin="15,5,15,5">
                    <TextBox Style="{DynamicResource SearchTextboxColor}"
                             x:Name="SearchTextBox"
                             Padding="35,0,5,0"/>
                    <Button Style="{DynamicResource SearchButtonColor}"
                            HorizontalAlignment="Left"/>
                </Grid>
                <Grid Grid.Column="3">
                    <Button Style="{DynamicResource CompramiseButtonColor}"
                            HorizontalAlignment="Left"
                            Width="50"/>
                    <Button Width="50"
                            HorizontalAlignment="Center"/>
                    <Button Width="50"
                            HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- Main -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="395"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>
            <Grid Margin="0,0,0,15" ClipToBounds="True">
                <Image  Source="/banners/banner_1.png" Stretch="UniformToFill"/>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Margin="0,0,15,0">

                </Grid>
                <Grid Grid.Column="1" Margin="0,0,15,0">

                </Grid>
                <Grid Grid.Column="2" Margin="0,0,15,0">

                </Grid>
                <Grid Grid.Column="3">

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
