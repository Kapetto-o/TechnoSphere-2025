<Window x:Class="TechnoSphere_2025.WindowMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TechnoSphere_2025"
        mc:Ignorable="d"
        WindowStyle="None"
        FontFamily="Roboto"
        ResizeMode="NoResize"
        Title="TechnoSphere-2025"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Style="{DynamicResource BackgroundColor}" Icon="/icon/LogoMiniGreen_64x64.png">

    <Grid>
        <Grid Panel.ZIndex="100">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="155"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <Grid x:Name="WindowControl_Moving"
                  Background="Transparent" 
                  Panel.ZIndex="1"
                  MouseLeftButtonDown="WindowControl_Moving_MouseLeftButtonDown"
                  Width="930"
                  Height="35"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Left"
                  Grid.ColumnSpan="3"/>
            <Grid x:Name="WindowsControl_Button"
                  Grid.Column="3"
                  Panel.ZIndex="1"
                  Width="70"
                  Height="35"
                  HorizontalAlignment="Right" 
                  VerticalAlignment="Top">
                <!-- Кнопка «Скрытия окна» -->
                <Button x:Name="HideButton"
                        Style="{DynamicResource HideColor_1}"
                        ContentTemplate="{StaticResource ShowIconTemplate}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Click="Show_Click"/>

                <!-- Кнопка «Закрытия окна» -->
                <Button x:Name="CloseButton"
                        Style="{DynamicResource CloseColor_1}"
                        ContentTemplate="{StaticResource CloseIconTemplate}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="35,0,0,0"
                        Click="Close_Click"/>
            </Grid>
        </Grid>
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>