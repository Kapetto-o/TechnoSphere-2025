<Window x:Class="TechnoSphere_2025.WindowMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TechnoSphere_2025"
        mc:Ignorable="d"
        WindowStyle="None"
        FontFamily="Roboto"
        ResizeMode="NoResize"
        Title="TechnoSphere-2025"
        Height="700" Width="1000"
        Icon="icon/Green_64x64.png"
        WindowStartupLocation="CenterScreen"
        Style="{DynamicResource BackgroundColor}">
    <Window.Resources>
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Width"       Value="35"/>
            <Setter Property="Height"      Value="35"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground"  Value="#1A5832"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для скрывающей кнопки -->
        <Style x:Key="ShowButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#cccccc"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для закрывающей кнопки -->
        <Style x:Key="CloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E71222"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ShowIconTemplate">
            <!-- Иконка скрывания окна -->
            <Grid Width="35" Height="35">
                <Path Data="M8,17 L28,17"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="CloseIconTemplate">
            <!-- Иконка закрытия окна -->
            <Grid Width="35" Height="35">
                <Path Data="M10,10 L25,25"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"/>
                <Path Data="M25,10 L10,25"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid x:Name="WindowControl_Moving" Background="Transparent" Panel.ZIndex="1" MouseLeftButtonDown="WindowControl_Moving_MouseLeftButtonDown" Margin="0,0,70,665" Grid.ColumnSpan="2"/>
        <Grid x:Name="WindowsControl_Button" Panel.ZIndex="1" Width="70" Height="35" HorizontalAlignment="Right" VerticalAlignment="Top">
            <!-- Кнопка «минимизировать» -->
            <Button Style="{StaticResource ShowButtonStyle}"
                    ContentTemplate="{StaticResource ShowIconTemplate}"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Click="Show_Click"/>

            <!-- Кнопка «закрыть» -->
            <Button Style="{StaticResource CloseButtonStyle}"
                    ContentTemplate="{StaticResource CloseIconTemplate}"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="35,0,0,0"
                    Click="Close_Click"/>
        </Grid>
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
    </Grid>
</Window>