<Page x:Class="TechnoSphere_2025.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TechnoSphere_2025"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="AuthorizationPage">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Grid Style="{DynamicResource ForegraundColor}">
            <!-- Левая часть -->
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>
            <StackPanel Margin="15" VerticalAlignment="Bottom">
                <TextBlock Text="Добро пожаловать!"
                           Style="{DynamicResource HeadlineColor_1_1}"
                           Margin="0,0,0,30"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Прежде чем продолжить, войдите в свой аккаунт."
                           Style="{DynamicResource MainlineColor_1}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <!-- Правая часть -->
            <Grid.RowDefinitions>
                <RowDefinition Height="1.65*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>

            <StackPanel MaxWidth="480" Grid.Row="1" VerticalAlignment="Center" Margin="15,0,15,0">
                <!-- Заголовок -->
                <TextBlock Text="Авторизация"
                           Style="{DynamicResource HeadlineColor_1_2}"
                           Margin="0,0,0,30"
                           HorizontalAlignment="Center"/>

                <!-- Поле ввода E-mail -->
                <TextBlock Text="Ваш E-mail"
                           Style="{DynamicResource MainlineColor_2}"
                           Margin="0,0,0,5"/>

                <TextBox Style="{DynamicResource TextBoxColor}"
                         Margin="0,0,0,15"/>

                <!-- Поле ввода пароля -->
                <TextBlock Text="Пароль"
                           Style="{DynamicResource MainlineColor_2}"
                           Margin="0,0,0,5"/>

                <TextBox Style="{DynamicResource TextBoxColor}"
                         Margin="0,0,0,30"/>

                <!-- Кнопка "Войти" -->
                <Button Content="Войти"
                        Style="{DynamicResource ButtonColor}"
                        x:Name="Login"
                        Click="Login_Click"
                        Margin="0,0,0,30">
                </Button>

                <StackPanel Orientation="Horizontal">
                    <!-- Переход в регистрацию -->
                    <TextBlock Text="Нет аккаунта?"
                           Style="{DynamicResource MainlineColor_2}"
                               Margin="0,0,5,0"/>
                    <TextBlock Style="{StaticResource Mainline_2}">
                        <Hyperlink Click="GoToRegister_Click" Foreground="#1A5832" TextDecorations="{x:Null}">
                            Зарегистрироваться
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>