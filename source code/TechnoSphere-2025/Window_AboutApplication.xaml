<Window x:Class="TechnoSphere_2025.Window_AboutApplication"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TechnoSphere_2025"
        mc:Ignorable="d"
        Title="О приложении"
        Width="471" Height="210"
        WindowStyle="None"
        ResizeMode="NoResize"
        FontFamily="Roboto"
        WindowStartupLocation="CenterOwner"
        Icon="/icons/LogoMiniGreen_64x64.png"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid>
        <Grid Height="30" 
              VerticalAlignment="top"
              Margin="0,0,30,0"
              MouseLeftButtonDown="WindowControl_Moving_MouseLeftButtonDown"
              Background="Transparent"
              Panel.ZIndex="1"/>

        <Button x:Name="CloseButton"
                ContentTemplate="{DynamicResource CloseIconTemplate}"
                Style="{DynamicResource CloseColor_2}"
                Width="35" Height="35"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Click="Close_Click"
                Panel.ZIndex="1"/>

        <Border Style="{DynamicResource HederWindowColor}" CornerRadius="4" BorderThickness="2">
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Image Source="{DynamicResource LogoMiniIcon}"/>
                    <TextBlock Text="{DynamicResource Loc_AboutApp}"
                               Style="{DynamicResource HeadlineColor_2-2}"
                               Margin="15,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,30,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15" Height="18">
                        <TextBlock Text="{DynamicResource Loc_Version}" Style="{DynamicResource MainlineColor_2_2}"/>
                        <TextBlock Text="v1.0"
                                    Style="{DynamicResource MainlineColor_2_2}"
                                    Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15" Height="18">
                        <TextBlock Text="{DynamicResource Loc_Developer}" Style="{DynamicResource MainlineColor_2_2}"/>
                        <TextBlock Text="Kapetto-o"
                                    Style="{DynamicResource MainlineColor_2_2}"
                                    Margin="10,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Height="18">
                        <TextBlock Text="GitHub:" Style="{DynamicResource MainlineColor_2_2}"/>
                        <TextBlock Style="{DynamicResource MainlineColor_2_2}"
                                   Margin="10,0,0,0">
                            <Hyperlink NavigateUri="https://github.com/Kapetto-o/TechnoSphere-2025"
                                       TextDecorations="{x:Null}"
                                       Foreground="{DynamicResource BrushHyperlinkColor}"
                                       RequestNavigate="BrowserLink_RequestNavigate">
                                https://github.com/Kapetto-o/TechnoSphere-2025
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>