<UserControl x:Class="TechnoSphere_2025.controls.header.HeaderControl_User"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TechnoSphere_2025.controls.header"
             xmlns:controlsHeaderBase="clr-namespace:TechnoSphere_2025.controls.header"
             Width="1000" Height="80">
    <Grid Style="{DynamicResource ForegraundColor}">
        <Grid Grid.Row="0" Style="{DynamicResource ForegraundColor}">
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="45"/>
            </Grid.RowDefinitions>

            <controlsHeaderBase:HeaderControlBase x:Name="HeaderControlBase"/>

            <!-- Header_2 -->
            <Grid Grid.Row="1" Margin="5,0,15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Style="{DynamicResource ButtonIconColor}">
                    <Image Source="{DynamicResource BurgerIcon}" Width="25"/>
                </Button>
                <Button Grid.Column="1"
                        Style="{DynamicResource ButtonIconColor}"
                        Margin="5,0,0,0">
                    <TextBlock Text="{DynamicResource Loc_Stock}"
                               Style="{StaticResource Headerline}"
                               Margin="10,0,10,0"/>
                </Button>

                <Grid Grid.Column="2" Margin="15,5,15,5">
                    <TextBox x:Name="SearchTextBox"
                             Style="{DynamicResource SearchTextboxColor}"
                             Height="35"
                             Padding="35,0,5,0"/>
                    <Button Style="{DynamicResource SearhButtonIconColor}"
                            Width="35"
                            HorizontalAlignment="Left">
                        <Image Source="{DynamicResource SearchIcon}" Height="25"/>
                    </Button>
                </Grid>

                <Grid Grid.Column="4">
                    <Button Style="{DynamicResource ButtonIconColor}"
                            Width="50"
                            HorizontalAlignment="Left">
                        <Image Source="{DynamicResource ComparisonIcon}" Height="25"/>
                    </Button>
                    <Button Style="{DynamicResource ButtonIconColor}"
                            Width="50"
                            HorizontalAlignment="Center">
                        <Image Source="{DynamicResource FavoriteIcon}"/>
                    </Button>
                    <Button Style="{DynamicResource ButtonIconColor}"
                            Width="50"
                            HorizontalAlignment="Right">
                        <Image Source="{DynamicResource BasketIcon}"/>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>