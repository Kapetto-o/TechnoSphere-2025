<UserControl x:Class="TechnoSphere_2025.controls.ProductCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TechnoSphere_2025.controls"
             xmlns:models="clr-namespace:TechnoSphere_2025.models"
             d:DataContext="{d:DesignInstance Type=models:ProductViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="750">
    <Grid>
        <Button Style="{DynamicResource EmptyButtonStyle}">
            <Border Style="{DynamicResource ProductCartdBorderColor}"
                    Background="{DynamicResource BrushBackgroundColor}"
                    Width="750">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="210"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Image Width="200" Height="200"
                               Stretch="UniformToFill"
                               Source="{Binding ImagePath,Converter={StaticResource ImagePathToSourceConverter}}"/>
                        <Button x:Name="AddFavorite"
                                Style="{StaticResource EmptyButtonStyle}"
                                Command="{Binding ToggleFavoriteCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="10"
                                Panel.ZIndex="1">
                            <Image Height="18">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Source" Value="{DynamicResource FavoriteIconProductOff}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                <Setter Property="Source" Value="{DynamicResource FavoriteIconProductOn}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Button>
                    </Grid>

                    <Grid Grid.Column="1" Margin="15,10">
                        <StackPanel>
                            <TextBlock x:Name="ProductName"
                                       Text="{Binding Name}"
                                       Style="{DynamicResource MainlineColor_2_3}"
                                       Width="310"
                                       TextWrapping="Wrap"/>
                            <StackPanel x:Name="StarRating"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        Margin="0,10,0,5">
                                <Image x:Name="Star_1"
                                       Height="15"
                                       Source="{DynamicResource StarIconOn}"/>
                                <Image x:Name="Star_2"
                                       Height="15"
                                       Margin="1,0,0,0"
                                       Source="{DynamicResource StarIconOn}"/>
                                <Image x:Name="Star_3"
                                       Height="15"
                                       Margin="1,0,0,0"
                                       Source="{DynamicResource StarIconOn}"/>
                                <Image x:Name="Star_4"
                                       Height="15"
                                       Margin="1,0,0,0"
                                       Source="{DynamicResource StarIconOn}"/>
                                <Image x:Name="Star_5"
                                       Height="15"
                                       Margin="1,0,0,0"
                                       Source="{DynamicResource StarIconOff}"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding MainCharacteristics}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{DynamicResource MainlineColor_2_1}"/>
                                            <TextBlock Text="{Binding Value}"
                                                       Style="{DynamicResource MainlineColor_2_3}"
                                                       Margin="10,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="2"
                          Background="#fafafa">
                        <Grid Margin="10,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="160"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,10">
                                <Button x:Name="CompareButton"
                                        Style="{StaticResource EmptyButtonStyle}"
                                        Height="18"
                                        Click="CompareButton_Click"
                                        HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{DynamicResource ComparisonIconCardProduct}" Height="18"/>
                                        <TextBlock Text="{Binding IsInComparison, Converter={StaticResource BoolToCompareTextConverter}}"
                                                   Style="{DynamicResource MainlineColor_2_1}"
                                                   VerticalAlignment="Center"
                                                   Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Button>

                                <Border Height="28"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"
                                    CornerRadius="4"
                                    Background="{DynamicResource BrushGreenColor}"
                                    Visibility="{Binding Installment, Converter={StaticResource NullToVisibilityConverter}}">
                                    <StackPanel x:Name="InstallmentPlan"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="10,0">
                                        <TextBlock Text="от"
                                               Style="{DynamicResource MainlineColor_2_2}"
                                               VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Installment, StringFormat={}{0:N0}}"
                                               Margin="5,0"
                                               Style="{DynamicResource HeadlineColor_2-2}"
                                               VerticalAlignment="Center"/>
                                        <TextBlock Text=" р./мес."
                                               Style="{DynamicResource MainlineColor_2_2}"
                                               VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal"
                                        Margin="0,10,0,0"
                                        VerticalAlignment="Center">

                                    <TextBlock Text="{Binding PromoPrice, StringFormat={}{0:N0}}"
                                          Style="{DynamicResource HeadlineColor_1_2}"
                                          Foreground="Red"
                                          Visibility="{Binding PromoPrice, Converter={StaticResource NotNullToVisibilityConverter}}"/>
                                    <TextBlock Text=" р."
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           Foreground="Red"
                                           Visibility="{Binding PromoPrice, Converter={StaticResource NotNullToVisibilityConverter}}"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"/>

                                    <TextBlock Text="{Binding Price, StringFormat={}{0:N0}}"
                                           TextDecorations="Strikethrough"
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           Margin="5,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding PromoPrice,
                                           Converter={StaticResource NotNullToVisibilityConverter}}"/>
                                    <TextBlock Text=" р."
                                           TextDecorations="Strikethrough"
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           Margin="2,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding PromoPrice, Converter={StaticResource NotNullToVisibilityConverter}}"
                                           FontSize="8"/>

                                    <TextBlock Text="{Binding Price, StringFormat={}{0:N0}}"
                                           Style="{DynamicResource HeadlineColor_1_2}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding PromoPrice,
                                           Converter={StaticResource NullToVisibilityInverseConverter}}"/>

                                    <TextBlock Text=" р."
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"
                                           Visibility="{Binding PromoPrice,
                                           Converter={StaticResource NullToVisibilityInverseConverter}}"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock x:Name="Availability"
                                   Text="{Binding InStock, Converter={StaticResource BoolToAvailabilityTextConverter}}"
                                   Style="{DynamicResource MainlineColor_2_1}"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,10"/>
                            <Button Grid.Row="1"
                                    x:Name="AddToBasketButton"
                                    Style="{DynamicResource AddBasketButtonColor}"
                                    Panel.ZIndex="1"
                                    IsEnabled="{Binding InStock}"
                                    Opacity="{Binding InStock, Converter={StaticResource BoolToOpacityConverter}}"
                                    Click="AddToBasketButton_Click">
                                <TextBlock Text="{Binding IsInBasket, Converter={StaticResource BoolToInBasketTextConverter}}"
                                           Style="{DynamicResource MainlineColor_2_2}"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Button>
    </Grid>
</UserControl>