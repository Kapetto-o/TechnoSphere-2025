<UserControl x:Class="TechnoSphere_2025.controls.ProductCard_Panel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TechnoSphere_2025.controls"
             xmlns:models="clr-namespace:TechnoSphere_2025.models"
             d:DataContext="{d:DesignInstance Type=models:ProductViewModel}"
             mc:Ignorable="d">
    <Grid>
        <Button Style="{DynamicResource EmptyButtonStyle}">
            <Border Style="{DynamicResource ProductCartdBorderColor}"
                    Background="{DynamicResource BrushBackgroundColor}">
                <Grid Margin="15" Width="200" Height="350">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="200"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Background="White">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            
                            <Grid Grid.Column="1">
                                <Image Width="200" Height="200"
                                       Stretch="UniformToFill"
                                       Source="{Binding ImagePath,Converter={StaticResource ImagePathToSourceConverter}}"/>
                                <Button x:Name="AddFavorite"
                                        Style="{StaticResource EmptyButtonStyle}"
                                        Command="{Binding ToggleFavoriteCommand}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="10"
                                        Panel.ZIndex="1">
                                    <Image Height="18">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Source" Value="{DynamicResource FavoriteIconProductOff}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                        <Setter Property="Source" Value="{DynamicResource FavoriteIconProductOn}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Button>
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="1">
                            <TextBlock x:Name="ProductName"
                                       Text="{Binding Name}"
                                       Style="{DynamicResource MainlineColor_2_3}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                        
                        <Grid Grid.Row="2">
                            <StackPanel x:Name="StarRating"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        Margin="0,10,0,5">
                                <Image x:Name="Star_1"
                                       Height="15"
                                       Source="{DynamicResource StarIconOn}"/>
                                <Image x:Name="Star_2"
                                       Height="15"
                                       Margin="1,0,0,0"
                                       Source="{DynamicResource StarIconOn}"/>
                                <Image x:Name="Star_3"
                                       Height="15"
                                       Margin="1,0,0,0"
                                       Source="{DynamicResource StarIconOn}"/>
                                <Image x:Name="Star_4"
                                       Height="15"
                                       Margin="1,0,0,0"
                                       Source="{DynamicResource StarIconOn}"/>
                                <Image x:Name="Star_5"
                                       Height="15"
                                       Margin="1,0,0,0"
                                       Source="{DynamicResource StarIconOff}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="3">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,10,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding PromoPrice, StringFormat={}{0:N0}}"
                                          Style="{DynamicResource HeadlineColor_1_2}"
                                          Foreground="Red"
                                          Visibility="{Binding PromoPrice, Converter={StaticResource NotNullToVisibilityConverter}}"/>
                                <TextBlock Text=" р."
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           Foreground="Red"
                                           Visibility="{Binding PromoPrice, Converter={StaticResource NotNullToVisibilityConverter}}"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"/>

                                <TextBlock Text="{Binding Price, StringFormat={}{0:N0}}"
                                           TextDecorations="Strikethrough"
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           Margin="5,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding PromoPrice,
                                           Converter={StaticResource NotNullToVisibilityConverter}}"/>
                                <TextBlock Text=" р."
                                           TextDecorations="Strikethrough"
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           Margin="2,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding PromoPrice, Converter={StaticResource NotNullToVisibilityConverter}}"
                                           FontSize="8"/>

                                <TextBlock Text="{Binding Price, StringFormat={}{0:N0}}"
                                           Style="{DynamicResource HeadlineColor_1_2}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding PromoPrice,
                                           Converter={StaticResource NullToVisibilityInverseConverter}}"/>

                                <TextBlock Text=" р."
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"
                                           Visibility="{Binding PromoPrice,
                                           Converter={StaticResource NullToVisibilityInverseConverter}}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="5">
                            <Button Style="{DynamicResource EmptyButtonStyle}"
                                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                    Click="DeleteButton_Click">
                                <TextBlock Text="Удалить"
                                       Style="{DynamicResource DeleteTextBlockColor}"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Button>
    </Grid>
</UserControl>
