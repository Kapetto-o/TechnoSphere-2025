<Window x:Class="TechnoSphere_2025.WindowMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TechnoSphere_2025"
        mc:Ignorable="d"
        Title="TechnoSphere-2025"
        Width="1000" Height="700"
        Style="{DynamicResource BackgroundColor}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Icon="/icon/LogoMiniGreen_64x64.png"
        FontFamily="Roboto">

    <Grid>
        <Grid x:Name="WindowControl_Moving"
              Width="930" Height="35"
              VerticalAlignment="Top"
              Margin="0,0,70,0"
              Background="Transparent"
              MouseLeftButtonDown="WindowControl_Moving_MouseLeftButtonDown"
              Panel.ZIndex="100"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Height="35"
                    Panel.ZIndex="101">
            <Button x:Name="HideButton"
                    ContentTemplate="{StaticResource ShowIconTemplate}"
                    Style="{DynamicResource HideColor_1}"
                    Width="35" Height="35"
                    Click="Show_Click"/>
            <Button x:Name="CloseButton"
                    ContentTemplate="{StaticResource CloseIconTemplate}"
                    Style="{DynamicResource CloseColor_1}"
                    Width="35" Height="35"
                    Click="Close_Click"/>
        </StackPanel>
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>