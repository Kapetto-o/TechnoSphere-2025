<Page x:Class="TechnoSphere_2025.modules.shared.PageSearchResults"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TechnoSphere_2025.modules.shared"
      xmlns:controlsProductCard="clr-namespace:TechnoSphere_2025.controls"
      xmlns:models="clr-namespace:TechnoSphere_2025.models"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Search">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Хедер -->
            <RowDefinition Height="Auto"/>
            <!-- Контент каталога -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ContentControl x:Name="HeaderHost" Grid.Row="0"/>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="15,5,0,0">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{DynamicResource HomeIcon}"
                           Width="15" Height="15"
                           HorizontalAlignment="Left"/>
                    <TextBlock Text=">"
                               Style="{DynamicResource MainlineColor_2_1}"
                               Margin="5,0"/>
                    <TextBlock Text="Поиск"
                               Style="{DynamicResource MainlineColor_2_1}"
                               Margin="5,0"/>
                    <TextBlock Text=">"
                               Style="{DynamicResource MainlineColor_2_1}"
                               Margin="5,0"/>
                    <TextBlock Text="{Binding Query}"
                               Style="{DynamicResource MainlineColor_2_3}"
                               Margin="5,0"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="15,5,0,0">
                <TextBlock Text="{Binding Query}"
                            Style="{DynamicResource HeadlineColor_2-1}"/>

                <TextBlock Text="{Binding Results.Count, StringFormat=Найдено {0} товаров}"
                           Style="{DynamicResource MainlineColor_2_1}"
                           HorizontalAlignment="Center"/>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="760"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <ComboBox HorizontalAlignment="Right"
                          SelectedIndex="0"
                          Style="{StaticResource ComboBoxColor}"
                          Margin="0,0,5,0">
                        <ComboBoxItem>
                            <TextBlock Text="Сначала отзывы"
                                  Style="{DynamicResource MainlineColor_2_1}"/>
                        </ComboBoxItem>
                        <ComboBoxItem>
                            <TextBlock Text="Сначала подешевле"
                                   Style="{DynamicResource MainlineColor_2_1}"/>
                        </ComboBoxItem>
                        <ComboBoxItem>
                            <TextBlock Text="Сначала подороже"
                                   Style="{DynamicResource MainlineColor_2_1}"/>
                        </ComboBoxItem>
                    </ComboBox>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="-10,10,-10,0">
                        <ItemsControl ItemsSource="{Binding Results}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <controlsProductCard:ProductCard Margin="0,10"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
