<Page x:Class="TechnoSphere_2025.modules.shared.PageCatalog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TechnoSphere_2025.modules.shared"
      xmlns:header="clr-namespace:TechnoSphere_2025.controls.header"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="PageCatalog">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <!-- Хедер -->
            <RowDefinition Height="Auto"/>
            <!-- Контент каталога -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ContentControl x:Name="HeaderHost"
                        Grid.Row="0"/>

        <!-- Основное содержимое страницы -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid Margin="15,5,0,0" Grid.Row="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Каталог"
                               Style="{DynamicResource MainlineColor_2_1}"/>
                    <TextBlock Text=">"
                               Style="{DynamicResource MainlineColor_2_1}"
                               Margin="5,0,5,0"/>
                    <TextBlock Text="Пылесосы"
                               Style="{DynamicResource MainlineColor_2_1}"/>
                    <TextBlock Text=">"
                               Style="{DynamicResource MainlineColor_2_1}"
                               Margin="5,0,5,0"/>
                    <TextBlock Text="Ручные пылесосы"
                               Style="{DynamicResource MainlineColor_2_3}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="15,5,0,0">
                <TextBlock Text="Ручные пылесосы"
                           Style="{DynamicResource HeadlineColor_2-1}"/>
            </Grid>
            <Grid Grid.Row="2" Margin="15,5,15,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Border Style="{DynamicResource BorderColor}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Фильтры"
                                       Grid.Row="0"
                                       Style="{DynamicResource MainlineColor_2_3}"
                                       Margin="10,5,10,0"/>

                            <StackPanel Grid.Row="1" Margin="10,0,10,0">
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Стоимость"
                                               Style="{DynamicResource MainlineColor_2_3}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBox Style="{DynamicResource TextBoxColor}"
                                                  Width="94" Height="30"/>
                                        <TextBox Style="{DynamicResource TextBoxColor}"
                                                 Width="94" Height="30"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Text="Производитель"
                                               Style="{DynamicResource MainlineColor_2_3}"/>
                                    <ComboBox Margin="0,5,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Content="Показать"
                                    Grid.Row="2"
                                    Style="{DynamicResource ButtonColor}"
                                    FontSize="20"/>
                        </Grid>
                    </Border>
                </Grid>
                <Grid Grid.Column="1" Margin="10,0,0,0">
                    <ListBox x:Name="ProductsList"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
