<Window x:Class="TechnoSphere_2025.modules.customer.Window_Favourites"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TechnoSphere_2025.modules.customer" xmlns:controlsProductCard="clr-namespace:TechnoSphere_2025.controls"
        mc:Ignorable="d"
        Title="Favourites" Height="600" Width="780"
        WindowStyle="None"
        ResizeMode="NoResize"
        FontFamily="Roboto"
        WindowStartupLocation="CenterOwner"
        Icon="/assets/icons/LogoMiniGreen_64x64.png"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Style="{DynamicResource BorderColor}"
            CornerRadius="4"
            BorderThickness="2"
            Background="{DynamicResource BrushBackgroundColor}">
        <Grid Margin="15">
            <Grid Height="35" 
              VerticalAlignment="Top"
              MouseLeftButtonDown="WindowControl_Moving_MouseLeftButtonDown"
              Background="Transparent"
              Panel.ZIndex="1"
              Margin="-15,-15,20,0"/>

            <Button x:Name="CloseButton"
                ContentTemplate="{DynamicResource CloseIconTemplate}"
                Style="{DynamicResource CloseColor_1}"
                Width="35" Height="35"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Click="Close_Click"
                Panel.ZIndex="1"
                Margin="-15"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Image Source="{DynamicResource LogoMiniIcon_Green}"/>
                        <TextBlock Text="Избранное"
                           Style="{DynamicResource HeadlineColor_2-1}"
                           Margin="5,0,0,0"
                           VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="-5,15,-5,0">
                    <ListBox x:Name="ProductsList"
                        ItemContainerStyle="{StaticResource ProductsListItemStyle}"
                        ItemsSource="{Binding Favorites}"
                        ScrollViewer.VerticalScrollBarVisibility="Hidden"
                        ScrollViewer.CanContentScroll="False"
                        BorderThickness="0"
                        Background="Transparent" Grid.ColumnSpan="2">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <controlsProductCard:Product_card Margin="0,10"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
