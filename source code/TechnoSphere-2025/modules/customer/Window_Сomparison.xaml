<Window x:Class="TechnoSphere_2025.modules.customer.Window_Comparison"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TechnoSphere_2025.controls"
        xmlns:models="clr-namespace:TechnoSphere_2025.models"
        Title="Comparison" Height="600" Width="900"
        WindowStyle="None"
        ResizeMode="NoResize"
        FontFamily="Roboto"
        WindowStartupLocation="CenterOwner"
        Icon="/assets/icons/LogoMiniGreen_64x64.png"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.DataContext>
        <models:ComparisonViewModel/>
    </Window.DataContext>

    <Border Style="{DynamicResource BorderColor}"
            CornerRadius="4"
            BorderThickness="2"
            Background="{DynamicResource BrushBackgroundColor}">
        <Grid Margin="15">
            <Grid Height="35" 
                  VerticalAlignment="Top"
                  MouseLeftButtonDown="WindowControl_Moving_MouseLeftButtonDown"
                  Background="Transparent"
                  Panel.ZIndex="1"
                  Margin="-15,-15,20,0"/>

            <Button x:Name="CloseButton"
                    ContentTemplate="{DynamicResource CloseIconTemplate}"
                    Style="{DynamicResource CloseColor_1}"
                    Width="35" Height="35"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Click="Close_Click"
                    Panel.ZIndex="1"
                    Margin="-15"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Image Source="{DynamicResource LogoMiniIcon_Green}"/>
                        <TextBlock Text="Сравнение"
                                   Style="{DynamicResource HeadlineColor_2-1}"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <DockPanel Grid.Row="1" Margin="0,15,0,0">
                    <TabControl ItemsSource="{Binding Tabs}"
                                SelectedItem="{Binding ActiveTab, Mode=TwoWay}"
                                DockPanel.Dock="Top">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CategoryName}" Padding="8,4"/>
                            </DataTemplate>
                        </TabControl.ItemTemplate>

                        <TabControl.ContentTemplate>
                            <DataTemplate/>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <Button Style="{DynamicResource ButtonColor}"
                            Command="{Binding ClearTabCommand}"
                            DockPanel.Dock="Top"
                            Height="30"
                            Margin="0,-8,0,0">
                        <TextBlock Text="Очистить"
                                   Style="{DynamicResource MainlineColor_2_2}"/>
                    </Button>

                    <ScrollViewer x:Name="OuterScroll"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Hidden">
                        <DataGrid x:Name="CompareDataGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  CanUserSortColumns="False"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="False"
                                  CanUserResizeRows="False"
                                  SelectionMode="Single"
                                  SelectionUnit="Cell"
                                  IsReadOnly="True"
                                  Focusable="False"
                                  PreviewMouseWheel="CompareDataGrid_PreviewMouseWheel"
                                  Background="White"
                                  BorderThickness="0">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="White"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Style>
                            </DataGrid.Resources>
                        </DataGrid>
                    </ScrollViewer>
                </DockPanel>
            </Grid>
        </Grid>
    </Border>
</Window>