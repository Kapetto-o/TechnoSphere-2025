<Page x:Class="TechnoSphere_2025.modules.customer.PagePersonalAccount"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TechnoSphere_2025.modules.customer"
      xmlns:models="clr-namespace:TechnoSphere_2025.models"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PagePersonalAccount">
    <Page.DataContext>
        <models:OrdersViewModel/>
    </Page.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <!-- Хедер -->
            <RowDefinition Height="Auto"/>
            <!-- Контент каталога -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ContentControl x:Name="HeaderHost" Grid.Row="0"/>

        <!-- Основное содержимое страницы -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="15,5,0,0">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{DynamicResource HomeIcon}"
                       Width="15" Height="15"
                       HorizontalAlignment="Left"/>
                    <TextBlock Text=">"
                           Style="{DynamicResource MainlineColor_2_1}"
                           Margin="5,0"/>
                    <TextBlock Text="Личный кабинет"
                               Style="{DynamicResource MainlineColor_2_3}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="15,5,0,0">
                <TextBlock Text="Личный кабинет"
                       Style="{DynamicResource HeadlineColor_2-1}"/>
            </Grid>

            <Grid Grid.Row="2" Margin="15,5,15,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <TextBlock Text="Заказы"
                               Style="{DynamicResource MainlineColor_2_3}"/>
                    
                </Grid>

                <Grid Grid.Row="1">
                    <StackPanel>
                        <TextBlock Text="Мои заказы" FontSize="18" Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding Orders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <!-- Верхняя строка: №, дата, статус -->
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="Заказ №" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding OrderID}" Margin="2,0"/>
                                                <TextBlock Text=" | " Margin="5,0"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat=d MMM yyyy}" Margin="0,0,10,0"/>

                                                <!-- Новый статус -->
                                                <TextBlock Text="{Binding StatusName}"
             FontWeight="Bold"
             Margin="0,0,10,0"/>

                                                <!-- Кнопка отмены -->
                                                <Button Content="Отменить"
          Click="CancelOrder_Click"
          Tag="{Binding OrderID}"
          Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>


                                            <!-- Позиции заказа -->
                                            <ItemsControl ItemsSource="{Binding Items}" Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock TextWrapping="Wrap">
                        <Hyperlink
                          Click="OrderItem_Hyperlink_Click"
                          Tag="{Binding ProductID}">
                          <Run Text="{Binding Display, Mode=OneWay}"/>
                        </Hyperlink>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Итог -->
                                            <TextBlock Text="{Binding TotalAmount, StringFormat='Итого: {0:N2} р.'}"
                           HorizontalAlignment="Right" FontWeight="Bold" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
