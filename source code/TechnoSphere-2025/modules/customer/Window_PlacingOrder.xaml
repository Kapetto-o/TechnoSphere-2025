<Window x:Class="TechnoSphere_2025.modules.customer.Window_PlacingOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TechnoSphere_2025.modules.customer"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        FontFamily="Roboto"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Icon="/assets/icons/LogoMiniGreen_64x64.png"
        AllowsTransparency="True"
        Title="PlacingOrder" Height="400" Width="300">
    <Border Style="{DynamicResource BorderColor}"
            CornerRadius="4"
            BorderThickness="2"
            Background="{DynamicResource BrushBackgroundColor}">
        <Grid Margin="15">
            <Grid Height="35" 
              VerticalAlignment="Top"
              MouseLeftButtonDown="WindowControl_Moving_MouseLeftButtonDown"
              Background="Transparent"
              Panel.ZIndex="1"
              Margin="-15,-15,20,0"/>

            <Button x:Name="CloseButton"
                ContentTemplate="{DynamicResource CloseIconTemplate}"
                Style="{DynamicResource CloseColor_1}"
                Width="35" Height="35"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Click="Close_Click"
                Panel.ZIndex="1"
                Margin="-15"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Image Source="{DynamicResource LogoMiniIcon_Green}"/>
                        <TextBlock Text="Оформление заказа"
                           Style="{DynamicResource HeadlineColor_2-1}"
                           Margin="5,0,0,0"
                           VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0,15,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden" CanContentScroll="False">
                        <Grid Margin="0,0,0,15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,30">
                                <TextBlock Text="Контакная информация"
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15"/>

                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Имя"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               Margin="0,0,0,5"/>
                                    <TextBox Style="{DynamicResource TextBoxColor}"
                                             Height="30"/>
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock Text="Телефон"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               Margin="0,0,0,5"/>
                                    
                                    <TextBox Style="{DynamicResource TextBoxColor}"
                                             Height="30"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,0,30">
                                <TextBlock Text="Способ доставки"
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15"/>

                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Выбор способа доставки"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               Margin="0,0,0,10"/>
                                    <ComboBox FontFamily="Roboto">
                                        <ComboBoxItem Content="Самовывоз" FontFamily="Roboto"/>
                                        <ComboBoxItem Content="По адресу" FontFamily="Roboto"/>
                                    </ComboBox>

                                    <TextBlock Text="! адрес самовоза"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               FontSize="12"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock Text="Адрес"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               Margin="0,0,0,5"/>
                                    <TextBox Style="{DynamicResource TextBoxColor}"
                                             Height="30"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,0,0,30">
                                <TextBlock Text="Способ оплаты"
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15"/>

                                <StackPanel>
                                    <TextBlock Text="Выбор способа оплаты"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               Margin="0,0,0,10"/>
                                    <ComboBox FontFamily="Roboto">
                                        <ComboBoxItem Content="Наличными при получении" FontFamily="Roboto"/>
                                        <ComboBoxItem Content="Картой при получении" FontFamily="Roboto"/>
                                    </ComboBox>

                                    <CheckBox Margin="0,30,0,0">
                                        <TextBlock Text="В рассрочку"
                                                   Style="{DynamicResource MainlineColor_2_1}"/>
                                    </CheckBox>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Row="3">
                                <TextBlock Text="Оформить заказ"/>
                            </Button>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
