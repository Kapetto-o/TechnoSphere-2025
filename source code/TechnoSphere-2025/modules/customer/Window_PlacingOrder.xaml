<Window x:Class="TechnoSphere_2025.modules.customer.Window_PlacingOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TechnoSphere_2025.modules.customer"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="NoResize"
        FontFamily="Roboto"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Icon="/assets/icons/LogoMiniGreen_64x64.png"
        AllowsTransparency="True"
        Title="PlacingOrder" Height="400" Width="330">
    <Border Style="{DynamicResource BorderColor}"
            CornerRadius="4"
            BorderThickness="2"
            Background="{DynamicResource BrushBackgroundColor}">
        <Grid Margin="15">
            <Grid Height="35" 
                  VerticalAlignment="Top"
                  MouseLeftButtonDown="WindowControl_Moving_MouseLeftButtonDown"
                  Background="Transparent"
                  Panel.ZIndex="1"
                  Margin="-15,-15,20,0"/>

            <Button x:Name="CloseButton"
                    ContentTemplate="{DynamicResource CloseIconTemplate}"
                    Style="{DynamicResource CloseColor_1}"
                    Width="35" Height="35"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Click="Close_Click"
                    Panel.ZIndex="1"
                    Margin="-15"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Grid Grid.Row="0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{DynamicResource LogoMiniIcon_Green}"/>
                        <TextBlock Text="Оформление заказа"
                                   Style="{DynamicResource HeadlineColor_2-1}"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Содержимое -->
                <Grid Grid.Row="1" Margin="0,15,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden" CanContentScroll="False">
                        <Grid Margin="0,0,0,15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>

                            <!-- 1. Контактная информация -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock Text="Контактная информация"
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15"/>

                                <!-- Имя -->
                                <StackPanel Margin="0,0,0,5">
                                    <TextBlock Text="Имя"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               Margin="0,0,0,5"/>
                                    <TextBox x:Name="NameTextBox"
                                             Style="{DynamicResource TextBoxColor}"
                                             Height="30"/>
                                    <!-- Ошибка под именем -->
                                    <TextBlock x:Name="NameErrorText"
                                               Text="* Пожалуйста, введите имя"
                                               Foreground="Red"
                                               FontSize="12"
                                               Visibility="Collapsed"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Телефон -->
                                <StackPanel>
                                    <TextBlock Text="Телефон"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               Margin="0,0,0,5"/>

                                    <TextBox x:Name="PhoneTextBox"
                                             Style="{DynamicResource TextBoxColor}"
                                             Height="30"
                                             PreviewTextInput="PhoneTextBox_PreviewTextInput"
                                             MaxLength="15"/>
                                    <!-- Ошибка под телефоном -->
                                    <TextBlock x:Name="PhoneErrorText"
                                               Text="* Неверный формат номера"
                                               Foreground="Red"
                                               FontSize="12"
                                               Visibility="Collapsed"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- 2. Способ доставки -->
                            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                                <TextBlock Text="Способ доставки"
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15"/>

                                <!-- Выбор способа -->
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Выбор способа доставки"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               Margin="0,0,0,10"/>

                                    <ComboBox x:Name="DeliveryMethodComboBox"
                                              Style="{DynamicResource ComboBoxColor}"
                                              Width="296"
                                              SelectedIndex="0"
                                              SelectionChanged="DeliveryMethodComboBox_SelectionChanged">
                                        <ComboBoxItem Width="296">
                                            <TextBlock Text="Самовывоз"
                                                       Style="{DynamicResource MainlineColor_2_1}"/>
                                        </ComboBoxItem>
                                        <ComboBoxItem Width="296">
                                            <TextBlock Text="По адресу"
                                                      Style="{DynamicResource MainlineColor_2_1}"/>
                                        </ComboBoxItem>
                                    </ComboBox>

                                    <!-- Адрес для самовывоза -->
                                    <TextBlock x:Name="PickupAddressText"
                                               Text="ул. Центральная 12-105"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               FontSize="12"
                                               Margin="0,5,0,0"
                                               Visibility="Visible"/>
                                </StackPanel>

                                <!-- Блок ввода адреса, если "По адресу" -->
                                <StackPanel x:Name="DeliveryAddressBlock"
                                            Visibility="Collapsed"
                                            Margin="0,5,0,0">
                                    <TextBlock Text="Адрес"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               Margin="0,0,0,5"/>
                                    <TextBox x:Name="DeliveryAddressTextBox"
                                             Style="{DynamicResource TextBoxColor}"
                                             Height="30"/>
                                    <!-- Ошибка под адресом -->
                                    <TextBlock x:Name="AddressErrorText"
                                               Text="* Пожалуйста, введите адрес"
                                               Foreground="Red"
                                               FontSize="12"
                                               Visibility="Collapsed"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- 3. Способ оплаты -->
                            <StackPanel Grid.Row="2" Margin="0,0,0,20">
                                <TextBlock Text="Способ оплаты"
                                           Style="{DynamicResource MainlineColor_2_3}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15"/>

                                <StackPanel>
                                    <TextBlock Text="Выбор способа оплаты"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               Margin="0,0,0,10"/>

                                    <ComboBox x:Name="PaymentMethodComboBox"
                                              Style="{DynamicResource ComboBoxColor}"
                                              Width="296"
                                              SelectedIndex="0">
                                        <ComboBoxItem Width="296">
                                            <TextBlock Text="Наличными при получении"
                                                       Style="{DynamicResource MainlineColor_2_1}"/>
                                        </ComboBoxItem>
                                        <ComboBoxItem Width="296">
                                            <TextBlock Text="Картой при получении"
                                                       Style="{DynamicResource MainlineColor_2_1}"/>
                                        </ComboBoxItem>
                                    </ComboBox>

                                    <CheckBox x:Name="InstallmentCheckBox"
                                              Margin="0,20,0,0"
                                              Checked="InstallmentCheckBox_Checked"
                                              Unchecked="InstallmentCheckBox_Unchecked">
                                        <TextBlock Text="В рассрочку"
                                                   Style="{DynamicResource MainlineColor_2_1}"/>
                                    </CheckBox>

                                    <TextBlock x:Name="InstallmentInfoText"
                                               Text="Рассрочка оформляется на месте"
                                               Style="{DynamicResource MainlineColor_2_1}"
                                               FontSize="12"
                                               Margin="0,5,0,0"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- 4. Кнопка "Оформить заказ" -->
                            <Button Grid.Row="3"
                                    x:Name="SubmitOrderButton"
                                    Style="{DynamicResource ButtonColor}"
                                    Click="SubmitOrderButton_Click">
                                <TextBlock Text="Оформить заказ"
                                           Style="{DynamicResource MainlineColor_2_2}"/>
                            </Button>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>