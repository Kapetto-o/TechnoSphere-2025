<Page x:Class="TechnoSphere_2025.modules.customer.PageBasket"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TechnoSphere_2025"
      mc:Ignorable="d" 
      xmlns:controlsHeader="clr-namespace:TechnoSphere_2025.controls.header"
      xmlns:controlsProductCard="clr-namespace:TechnoSphere_2025.controls"
      Title="Home"
      d:DesignWidth="1000" d:DesignHeight="700">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <ContentControl x:Name="HeaderHost" Grid.Row="0"/>

        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Text="Корзина"
                       Style="{DynamicResource HeadlineColor_2-1}"/>

            <Grid Grid.Row="1" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="750"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Style="{StaticResource EmptyButtonStyle}"
                            Height="auto"
                            HorizontalAlignment="Right">
                        <TextBlock Text="Очистить корзину"
                                   Style="{StaticResource Mainline_2}"
                                   Foreground="{DynamicResource BrushLight_greenColor}"/>
                    </Button>

                    <ListBox x:Name="ProductsList"
                             Grid.Row="1"
                        ItemContainerStyle="{StaticResource ProductsListItemStyle}"
                        Margin="-5,0"
                        ScrollViewer.VerticalScrollBarVisibility="Hidden"
                        ScrollViewer.CanContentScroll="False"
                        BorderThickness="0"
                        Background="Transparent" Grid.ColumnSpan="2">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <controlsProductCard:ProductCard_Minimum Margin="0,10"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Grid Grid.Column="1" Margin="10,0,0,0">
                    <Border Style="{DynamicResource BorderColor}"
                            VerticalAlignment="Top">
                        <Grid MinHeight="100">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <TextBlock  Grid.Column="0"
                                            Text="К оплате:"
                                            Style="{DynamicResource MainlineColor_2_1}"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Margin="0,10,15,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="372827"
                                           Style="{DynamicResource HeadlineColor_1_2}"
                                           HorizontalAlignment="Right"
                                           MaxWidth="108"/>
                            </Grid>

                            <Button Grid.Row="1"
                                    Style="{DynamicResource ButtonColor}"
                                    VerticalAlignment="Bottom">
                                <TextBlock Text="Оформить заказ"
                                   Style="{DynamicResource MainlineColor_2_2}"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>