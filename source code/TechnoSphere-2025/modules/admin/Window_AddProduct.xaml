<Window x:Class="TechnoSphere_2025.modules.admin.Window_AddProduct"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:TechnoSphere_2025.models"
        mc:Ignorable="d"
        Title="Добавить товар"
        Width="400" Height="600"
        WindowStartupLocation="CenterOwner"
        FontFamily="Roboto"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="*"/>
            <!-- Содержимое (ScrollViewer) -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки Сохранить/Отмена -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="Новый товар"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"
                   Style="{DynamicResource HeadlineColor_1_2}"/>

        <!-- Форма в ScrollViewer -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="MainStack"
                        Orientation="Vertical"
                        Margin="0,0,0,10">
                <!-- 1. Название (RU) -->
                <TextBlock Text="Название (рус.):"
                           Style="{DynamicResource MainlineColor_2_1}"
                           Margin="0,0,0,2"/>
                <TextBox x:Name="NameRuTextBox"
                         Style="{DynamicResource TextBoxColor}"
                         Height="30"
                         Margin="0,0,0,10"/>

                <!-- 2. Название (ENG) -->
                <TextBlock Text="Название (eng.):"
                           Style="{DynamicResource MainlineColor_2_1}"
                           Margin="0,0,0,2"/>
                <TextBox x:Name="NameEngTextBox"
                         Style="{DynamicResource TextBoxColor}"
                         Height="30"
                         Margin="0,0,0,10"/>

                <!-- 3. Путь к изображению -->
                <TextBlock Text="Путь к фотографиям (папка/файл):"
                           Style="{DynamicResource MainlineColor_2_1}"
                           Margin="0,0,0,2"/>
                <TextBox x:Name="ImagePathTextBox"
                         Style="{DynamicResource TextBoxColor}"
                         Height="30"
                         Margin="0,0,0,10"/>

                <!-- 4. Базовая цена -->
                <TextBlock Text="Цена (руб.):"
                           Style="{DynamicResource MainlineColor_2_1}"
                           Margin="0,0,0,2"/>
                <TextBox x:Name="PriceTextBox"
                         Style="{DynamicResource TextBoxColor}"
                         Height="30"
                         Margin="0,0,0,10"/>

                <!-- 5. Акционная цена (можно оставить пустым) -->
                <TextBlock Text="Акционная цена (руб., либо пусто):"
                           Style="{DynamicResource MainlineColor_2_1}"
                           Margin="0,0,0,2"/>
                <TextBox x:Name="PromoPriceTextBox"
                         Style="{DynamicResource TextBoxColor}"
                         Height="30"
                         Margin="0,0,0,10"/>

                <!-- 6. Количество на складе -->
                <TextBlock Text="Количество на складе:"
                           Style="{DynamicResource MainlineColor_2_1}"
                           Margin="0,0,0,2"/>
                <TextBox x:Name="StockQuantityTextBox"
                         Style="{DynamicResource TextBoxColor}"
                         Height="30"
                         Margin="0,0,0,10"/>

                <!-- 7. Раздел «Характеристики» -->
                <TextBlock Text="Характеристики:"
                           Style="{DynamicResource HeadlineColor_2-1}"
                           Margin="0,10,0,5"/>

                <!-- Здесь динамически будут добавляться StackPanel-ы для каждой SpecType -->
                <StackPanel x:Name="SpecsStackPanel"
                            Orientation="Vertical"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки Сохранить и Отмена -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="CancelButton"
                    Style="{DynamicResource ButtonColor}"
                    Width="80"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click">
                <TextBlock Text="Отмена"
                           Style="{DynamicResource MainlineColor_2_2}"/>
            </Button>
            <Button x:Name="SaveButton"
                    Style="{DynamicResource ButtonColor}"
                    Width="100"
                    Click="SaveButton_Click">
                <TextBlock Text="Сохранить"
                           Style="{DynamicResource MainlineColor_2_2}"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>