<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/style/font/FontStyle.xaml"/>
        <ResourceDictionary Source="/style/Style.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    
    <Color x:Key="WhiteColor">#FFFFFF</Color>
    <Color x:Key="GrayColor">#353535</Color>
    <Color x:Key="GreenColor">#1A5832</Color>
    <Color x:Key="Light_greenColor">#387A2B</Color>

    <Color x:Key="BlackColor">#121212</Color>
    <Color x:Key="WhiteColor_1">#cccccc</Color>
    <Color x:Key="GrayColor_1">#1E1E1E</Color>
    <Color x:Key="GrayColor_2">#262626</Color>
    <Color x:Key="GrayColor_3">#303030</Color>
    <Color x:Key="Light_grayColor">#A0A0A0</Color>

    <SolidColorBrush x:Key="BrushWhiteColor" Color="{DynamicResource WhiteColor}"/>
    <SolidColorBrush x:Key="BrushGrayColor" Color="{DynamicResource GrayColor}"/>
    <SolidColorBrush x:Key="BrushGreenColor" Color="{DynamicResource GreenColor}"/>
    <SolidColorBrush x:Key="BrushLight_greenColor" Color="{DynamicResource Light_greenColor}"/>

    <SolidColorBrush x:Key="BrushBlackColor" Color="{DynamicResource BlackColor}"/>
    <SolidColorBrush x:Key="BrushWhiteColor_1" Color="{DynamicResource WhiteColor_1}"/>
    <SolidColorBrush x:Key="BrushGrayColor_1" Color="{DynamicResource GrayColor_1}"/>
    <SolidColorBrush x:Key="BrushGrayColor_2" Color="{DynamicResource GrayColor_2}"/>
    <SolidColorBrush x:Key="BrushGrayColor_3" Color="{DynamicResource GrayColor_3}"/>
    <SolidColorBrush x:Key="BrushLight_grayColor" Color="{DynamicResource Light_grayColor}"/>

    <SolidColorBrush x:Key="BrushIconColor" Color="{DynamicResource WhiteColor_1}"/>
    <SolidColorBrush x:Key="BrushSearchIconColor" Color="{DynamicResource WhiteColor_1}"/>
    <SolidColorBrush x:Key="BrushMainIconColor" Color="{DynamicResource WhiteColor_1}"/>
    <SolidColorBrush x:Key="BrushHyperlinkColor" Color="{DynamicResource Light_greenColor}"/>

    <!-- Фон -->
    <Style x:Key="BackgroundColor" TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource BrushBlackColor}"/>
    </Style>

    <!-- Второстепенный фон -->
    <Style x:Key="ForegraundColor" TargetType="Grid">
        <Setter Property="Background" Value="{DynamicResource BrushGrayColor_1}"/>
    </Style>

    <!-- Управление окном -->
    <!-- Скрыть окно -->
    <Style x:Key="HideColor_1" TargetType="Button" BasedOn="{StaticResource ShowButtonStyle}">
        <Setter Property="Foreground"  Value="{DynamicResource BrushIconColor}"/>
    </Style>
    <Style x:Key="HideColor_2" TargetType="Button" BasedOn="{StaticResource ShowButtonStyle}">
        <Setter Property="Foreground"  Value="{DynamicResource BrushIconColor}"/>
    </Style>

    <!-- Удалить окно -->
    <Style x:Key="CloseColor_1" TargetType="Button" BasedOn="{StaticResource CloseButtonStyle}">
        <Setter Property="Foreground"  Value="{DynamicResource BrushWhiteColor_1}"/>
    </Style>
    <Style x:Key="CloseColor_2" TargetType="Button" BasedOn="{StaticResource CloseButtonStyle}">
        <Setter Property="Foreground"  Value="{DynamicResource BrushWhiteColor_1}"/>
    </Style>
    
    <!-- Текст -->
    <!-- Заголовок_1 цвет_1 -->
    <Style x:Key="HeadlineColor_1_1" TargetType="TextBlock" BasedOn="{StaticResource Headline_1}">
        <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor_1}"/>
    </Style>

    <!-- Заголовок_1 цвет_2 (в темной теме цвета одинаковые) -->
    <Style x:Key="HeadlineColor_1_2" TargetType="TextBlock"  BasedOn="{StaticResource Headline_1}">
        <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor_1}"/>
    </Style>

    <!-- Заголовок_2 цвет_1 -->
    <Style x:Key="HeadlineColor_2-1" TargetType="TextBlock"  BasedOn="{StaticResource Headline_2}">
        <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor_1}"/>
    </Style>

    <!-- Заголовок_2 цвет_2 -->
    <Style x:Key="HeadlineColor_2-2" TargetType="TextBlock"  BasedOn="{StaticResource Headline_2}">
        <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor_1}"/>
    </Style>
    <!-- Основной_1 -->
    <Style x:Key="MainlineColor_1" TargetType="TextBlock" BasedOn="{StaticResource Mainline_1}">
        <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor_1}"/>
    </Style>

    <!-- Основной_2 цвет_1 -->
    <Style x:Key="MainlineColor_2_1" TargetType="TextBlock" BasedOn="{StaticResource Mainline_2}">
        <Setter Property="Foreground" Value="{DynamicResource BrushLight_grayColor}"/>
    </Style>

    <!-- Основной_2 цвет_2 -->
    <Style x:Key="MainlineColor_2_2" TargetType="TextBlock" BasedOn="{StaticResource Mainline_2}">
        <Setter Property="Foreground" Value="{DynamicResource BrushLight_grayColor}"/>
    </Style>

    <!-- Элементы управления -->
    <!-- TextBox в окнах регистрации и авторизации -->
    <Style x:Key="TextBoxColor" TargetType="TextBox" BasedOn="{StaticResource RegAut_TextBox}">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushWhiteColor_1}"/>
        <Setter Property="Background" Value="{DynamicResource BrushGrayColor_1}"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor_1}"/>
    </Style>

    <!-- Button в окнах регистрации и авторизации -->
    <Style x:Key="ButtonColor" TargetType="Button" BasedOn="{StaticResource RegAut_Button}">
        <Setter Property="Background" Value="{DynamicResource BrushGreenColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor_1}"/>
    </Style>

    <!-- Поиск -->
    <!-- Поле ввода поиска -->
    <Style x:Key="SearchTextboxColor" TargetType="TextBox" BasedOn="{StaticResource SearchTextBoxStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushGrayColor_1}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrushWhiteColor_1}"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushWhiteColor_1}"/>
    </Style>

    <!-- Иконки -->
    <Style x:Key="ButtonIconColor" TargetType="Button" BasedOn="{StaticResource ButtonIconStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BrushGrayColor_3}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SearhButtonIconColor" TargetType="Button" BasedOn="{StaticResource ButtonIconStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BannerButtonColor" TargetType="Button" BasedOn="{StaticResource BannerButtonStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="White"
                                          BlurRadius="10"
                                          ShadowDepth="0" 
                                          Opacity="0.7"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="HeaderPopupColor" TargetType="ContentControl" BasedOn="{StaticResource HeaderPopupStyle}">
        <Setter Property="Background" Value="{DynamicResource BrushGrayColor_2}"/>
    </Style>

    <Style x:Key="HeaderPopupButtonColor" TargetType="Button" BasedOn="{StaticResource HeaderPopupButtonStyle}">
        <Setter Property="Foreground" Value="{DynamicResource BrushIconColor}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BrushGrayColor_3}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="HederWindowColor" TargetType="Border">
        <Setter Property="BorderBrush" Value="{DynamicResource BrushLight_grayColor}"/>
        <Setter Property="Background" Value="{DynamicResource BrushGrayColor_1}"/>
    </Style>

    <Style x:Key="IconRadioButtonColor" TargetType="RadioButton" BasedOn="{StaticResource RadioButtonStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource BrushGrayColor_3}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource BrushLight_greenColor}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TextRadioButtonColor" TargetType="RadioButton" BasedOn="{StaticResource RadioButtonStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BrushGrayColor_3}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="{DynamicResource BrushLight_greenColor}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>