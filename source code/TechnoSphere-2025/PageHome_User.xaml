<Page x:Class="TechnoSphere_2025.PageHome_User"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TechnoSphere_2025"
      mc:Ignorable="d" 
      xmlns:controls="clr-namespace:TechnoSphere_2025.helper"
      Title="Home"
      d:DesignWidth="1000" d:DesignHeight="700">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <controls:HeaderControl x:Name="PageHeader"/>

        <!-- Main -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="395"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0"
                Style="{DynamicResource BannerButtonColor}"
                Margin="0,0,0,15">
                <Image Source="{DynamicResource BannerImage}" Stretch="UniformToFill"/>
            </Button>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,15,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{DynamicResource OriginalIcon}"
                           Height="60"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                               Text="{DynamicResource Loc_OriginalTechnique}"
                               Style="{DynamicResource HeadlineColor_2-1}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    </Grid>

                    <TextBlock Grid.Row="1"
                           Text="{DynamicResource Loc_OriginalTechniqueText}"
                           Style="{DynamicResource MainlineColor_2_1}"
                           TextWrapping="Wrap"/>
                </Grid>

                <Grid Grid.Column="1" Margin="0,0,15,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{DynamicResource SupportIcon}"
                           Height="60"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                               Text="{DynamicResource Loc_Stress-freeShopping}"
                               Style="{DynamicResource HeadlineColor_2-1}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    </Grid>

                    <TextBlock Grid.Row="1"
                           Text="{DynamicResource Loc_Stress-freeShoppingText}"
                           Style="{DynamicResource MainlineColor_2_1}"
                           TextWrapping="Wrap"/>

                </Grid>

                <Grid Grid.Column="2" Margin="0,0,15,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{DynamicResource DeliveryIcon}"
                           Width="54.43"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                               Text="{DynamicResource Loc_FreeShipping}"
                               Style="{DynamicResource HeadlineColor_2-1}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    </Grid>

                    <TextBlock Grid.Row="1"
                           Text="{DynamicResource Loc_FreeShippingText}"
                           Style="{DynamicResource MainlineColor_2_1}"
                           TextWrapping="Wrap"/>
                </Grid>

                <Grid Grid.Column="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{DynamicResource CatalogIcon}"
                           Width="54.43"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                              Text="{DynamicResource Loc_HugeSelection}"
                              Style="{DynamicResource HeadlineColor_2-1}"
                              VerticalAlignment="Center"
                              TextWrapping="Wrap"/>
                    </Grid>

                    <TextBlock Grid.Row="1"
                          Text="{DynamicResource Loc_HugeSelectionText}"
                          Style="{DynamicResource MainlineColor_2_1}"
                          TextWrapping="Wrap"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
