<Page x:Class="TechnoSphere_2025.PageUser_Home"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TechnoSphere_2025"
      xmlns:controls="clr-namespace:TechnoSphere_2025.helper"
      mc:Ignorable="d"
      Title="Home"
      d:DesignWidth="1000" d:DesignHeight="700">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <controls:HeaderControl x:Name="PageHeader"/>

        <!-- Main -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="395"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Style="{DynamicResource BannerButtonColor}">
                <Image Source="{DynamicResource BannerImage}" Stretch="UniformToFill"/>
            </Button>

            <Grid Grid.Row="1" Margin="0,10,0,15" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Button Width="50" Height="50"
                            Margin="0,0,10,0">
                        <Image/>
                    </Button>

                    <Button Width="50" Height="50">
                        <Image/>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" HorizontalAlignment="Center">
                <StackPanel>
                    <Button Width="500" Height="55"
                        Margin="0,0,0,10">
                        <TextBlock Text=""/>
                    </Button>
                    <Button Width="500" Height="55"
                            Margin="0,0,0,10">
                        <TextBlock Text=""/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>